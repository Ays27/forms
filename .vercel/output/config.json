{
  "version": 3,
  "overrides": {},
  "routes": [
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/builds/meta/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=1, immutable"
      },
      "src": "/_nuxt/builds/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_fonts/(.*)"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/_nuxt/(.*)"
    },
    {
      "src": "/_nuxt/builds/meta(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt/builds(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_fonts(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "src": "/_nuxt(.*)",
      "headers": {
        "cache-control": "public,max-age=31536000,immutable"
      },
      "continue": true
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "(?<__isr_route>/__nuxt_error)",
      "dest": "/__fallback"
    },
    {
      "src": "/signup",
      "dest": "/signup"
    },
    {
      "src": "/preview",
      "dest": "/preview"
    },
    {
      "src": "/login",
      "dest": "/login"
    },
    {
      "src": "/forms/new",
      "dest": "/forms/new"
    },
    {
      "src": "/api/responses",
      "dest": "/api/responses"
    },
    {
      "src": "/api/hello",
      "dest": "/api/hello"
    },
    {
      "src": "/api/forms/publish",
      "dest": "/api/forms/publish"
    },
    {
      "src": "/api/forms/my",
      "dest": "/api/forms/my"
    },
    {
      "src": "/api/forms/create",
      "dest": "/api/forms/create"
    },
    {
      "src": "/api/auth/hello",
      "dest": "/api/auth/hello"
    },
    {
      "src": "/__nuxt_error",
      "dest": "/__nuxt_error"
    },
    {
      "src": "/",
      "dest": "/index"
    },
    {
      "src": "/forms/responses/(?<id>[^/]+)",
      "dest": "/forms/responses/[id]"
    },
    {
      "src": "/forms/(?<slug>[^/]+)",
      "dest": "/forms/[slug]"
    },
    {
      "src": "/forms/(?<id>[^/]+)",
      "dest": "/forms/[id]"
    },
    {
      "src": "/f/(?<id>[^/]+)",
      "dest": "/f/[id]"
    },
    {
      "src": "/api/forms/share/(?<id>[^/]+)",
      "dest": "/api/forms/share/[id]"
    },
    {
      "src": "/api/forms/(?<id>[^/]+)/responses",
      "dest": "/api/forms/[id]/responses"
    },
    {
      "src": "/api/forms/(?<id>[^/]+)",
      "dest": "/api/forms/[id]"
    },
    {
      "src": "/api/_nuxt_icon/(?<collection>[^/]+)",
      "dest": "/api/_nuxt_icon/[collection]"
    },
    {
      "src": "/api/auth/(?:.*)",
      "dest": "/api/auth/[...]"
    },
    {
      "src": "/__nuxt_island/(?:.*)",
      "dest": "/__nuxt_island/[...]"
    },
    {
      "src": "/(.*)",
      "dest": "/__fallback"
    }
  ]
}