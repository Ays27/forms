import { db } from '~/server/db'
import { forms } from '~/server/schema'
import { eq } from 'drizzle-orm'

export default defineEventHandler(async (event) => {
  const slug = event.context.params.slug

  const form = await db
    .select()
    .from(forms)
    .where(eq(forms.slug, slug))
    .limit(1)

  return form[0]
})